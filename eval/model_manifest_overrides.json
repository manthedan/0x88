  "family_promotion_gates": {
    "ResidualCNN": {
      "promote_if": "beats current in-lane CNN baseline by >= +20 Elo at equal visits and is non-regressing on dev CE/top-k",
      "kill_if": "fails to improve over smaller/in-lane baseline after two comparable training/eval attempts or exceeds deploy latency budget without Elo gain",
      "anchor_protocol": "Stockfish/Maia UCI anchor or shared search-mode arena, deterministic classic PUCT, >=32 visits smoke then >=64 visits confirmation"
    },
    "ResidualCNN_AV": {
      "promote_if": "aux/AV-PUCT shows >= +30 Elo over equal-budget classic-PUCT CNN at 64 visits, with no Stockfish cp-loss regression on override diagnostics",
      "kill_if": "aux heads do not beat classic PUCT in two seeds/visit counts, or AV/Q diagnostics show systematic blunder amplification",
      "anchor_protocol": "classic PUCT baseline plus calibrated aux-PUCT candidate against Stockfish/Maia anchors and visit curve"
    },
    "ResidualCNNHybrid": {
      "promote_if": "beats same-scale residual CNN at equal visits and preserves browser latency/size budget",
      "kill_if": "hybrid head/trunk adds size or latency without anchor-Elo improvement over the simpler CNN lane",
      "anchor_protocol": "same openings and visits as current CNN anchor protocol"
    },
    "MoveFormer_CNN_AV": {
      "promote_if": "beats best equal-budget CNN/AV baseline on anchor arena and tactical/cp-loss diagnostics after sidecar/cache costs are included",
      "kill_if": "sidecar/cache/runtime complexity is not offset by anchor-Elo or tactical gain after one 10M and one 100M-scale attempt",
      "anchor_protocol": "bucketed ONNX export, classic and tuned aux-PUCT, Stockfish/Maia anchors, latency noted by legal-bucket size"
    },
    "CNN_ChannelFormer": {
      "promote_if": "beats same-dataset residual CNN by >= +20 Elo or materially improves latency/size at equal Elo",
      "kill_if": "no anchor gain over residual CNN after supervised e3/e6-style attempts; park as architecture note",
      "anchor_protocol": "same 10M/100M anchor arena as residual CNN comparator"
    },
    "SquareFormer": {
      "promote_if": "meets browser-deploy size/latency target and beats CNN floor at equal visits after h7/h8 cache training",
      "kill_if": "cannot match CNN floor after true h7/h8 cache training or misses browser deploy latency/size target",
      "anchor_protocol": "BT4/SquareFormer h7/h8 lane: classic PUCT first, PTQ deploy check, Stockfish/Maia anchors"
    }
  },
