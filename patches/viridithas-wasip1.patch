@@ -0,0 +1,118 @@
+use crate::{
+    chess::{piece::Piece, types::Square},
+    nnue::geometry::Bit,
+};
+
+use super::{BitRays, INCOMING_SLIDERS_MASK, INCOMING_THREATS_MASK, PERMUTATION, PIECE_TO_BIT};
+
+#[derive(Clone, Copy)]
+#[repr(transparent)]
+pub struct Vector {
+    pub raw: [u8; 64],
+}
+
+impl Vector {
+    #[expect(unused)]
+    pub fn flip(self) -> Self {
+        let mut raw = [0; 64];
+        raw[..32].copy_from_slice(&self.raw[32..]);
+        raw[32..].copy_from_slice(&self.raw[..32]);
+        Self { raw }
+    }
+
+    fn to_mask(&self) -> u64 {
+        let mut out = 0u64;
+        for (idx, &byte) in self.raw.iter().enumerate() {
+            if byte != 0 {
+                out |= 1u64 << idx;
+            }
+        }
+        out
+    }
+
+    unsafe fn load(ptr: *const u8) -> Self {
+        let mut raw = [0; 64];
+        unsafe { std::ptr::copy_nonoverlapping(ptr, raw.as_mut_ptr(), 64) };
+        Self { raw }
+    }
+
+    unsafe fn cast<T>(v: &T) -> Self {
+        unsafe { Self::load((v as *const T).cast::<u8>()) }
+    }
+}
+
+pub struct Permutation {
+    pub indexes: Vector,
+    pub valid: Vector,
+}
+
+pub fn permutation_for(focus: Square) -> Permutation {
+    let indexes = Vector { raw: PERMUTATION[focus.index()] };
+    let mut valid = [0; 64];
+    for (dst, &index) in valid.iter_mut().zip(indexes.raw.iter()) {
+        *dst = if index & 0x80 == 0 { 0xFF } else { 0 };
+    }
+    Permutation { indexes, valid: Vector { raw: valid } }
+}
+
+fn permute_mailbox_inner(permutation: &Permutation, mailbox: &Vector) -> (Vector, Vector) {
+    let mut permuted = [0; 64];
+    let mut bits = [0; 64];
+    for idx in 0..64 {
+        if permutation.valid.raw[idx] != 0 {
+            let src = usize::from(permutation.indexes.raw[idx]);
+            let piece = mailbox.raw[src];
+            permuted[idx] = piece;
+            bits[idx] = PIECE_TO_BIT[usize::from(piece)].0;
+        }
+    }
+    (Vector { raw: permuted }, Vector { raw: bits })
+}
+
+pub fn permute_mailbox(permutation: &Permutation, mailbox: &[Option<Piece>; 64]) -> (Vector, Vector) {
+    let mb = unsafe { Vector::load(mailbox.as_ptr().cast::<u8>()) };
+    permute_mailbox_inner(permutation, &mb)
+}
+
+pub fn permute_mailbox_ignoring(
+    permutation: &Permutation,
+    mailbox: &[Option<Piece>; 64],
+    ignore: Square,
+) -> (Vector, Vector) {
+    const NO_PIECE: u8 = unsafe { std::mem::transmute::<Option<Piece>, u8>(None) };
+    let mut mb = unsafe { Vector::load(mailbox.as_ptr().cast::<u8>()) };
+    mb.raw[usize::from(ignore.inner())] = NO_PIECE;
+    permute_mailbox_inner(permutation, &mb)
+}
+
+pub fn closest_occupied(bits: Vector) -> BitRays {
+    let occupied = bits.to_mask();
+    let o = occupied | 0x8181_8181_8181_8181;
+    BitRays((o ^ o.wrapping_sub(0x0303_0303_0303_0303)) & occupied)
+}
+
+pub fn incoming_attackers(bits: Vector, closest: BitRays) -> BitRays {
+    let mask = unsafe { Vector::cast(&INCOMING_THREATS_MASK) };
+    let mut raw = [0; 64];
+    for (idx, dst) in raw.iter_mut().enumerate() {
+        *dst = if bits.raw[idx] & mask.raw[idx] != 0 { 0xFF } else { 0 };
+    }
+    BitRays(Vector { raw }.to_mask()) & closest
+}
+
+pub fn incoming_sliders(bits: Vector, closest: BitRays) -> BitRays {
+    let mask = unsafe { Vector::cast(&INCOMING_SLIDERS_MASK) };
+    let mut raw = [0; 64];
+    for (idx, dst) in raw.iter_mut().enumerate() {
+        *dst = if bits.raw[idx] & mask.raw[idx] != 0 { 0xFF } else { 0 };
+    }
+    BitRays(Vector { raw }.to_mask()) & closest & BitRays::NON_KNIGHT
+}
+
+pub fn test_bit(bits: Vector, bit: Bit) -> BitRays {
+    let mut raw = [0; 64];
+    for (idx, dst) in raw.iter_mut().enumerate() {
+        *dst = if bits.raw[idx] & bit.0 != 0 { 0xFF } else { 0 };
+    }
+    BitRays(Vector { raw }.to_mask())
+}
