+#![allow(clippy::needless_range_loop)]
+
+pub const INNER_ARCH: &str = "wasm-scalar";
+
+#[derive(Clone, Copy)]
+#[repr(align(32))]
+pub struct VecI8(pub [i8; 32]);
+#[derive(Clone, Copy)]
+#[repr(align(32))]
+pub struct VecI16(pub [i16; 16]);
+#[derive(Clone, Copy)]
+#[repr(align(32))]
+pub struct VecI32(pub [i32; 8]);
+#[derive(Clone, Copy)]
+#[repr(align(32))]
+pub struct VecF32(pub [f32; 8]);
+#[derive(Clone, Copy)]
+#[repr(align(16))]
+pub struct Vec128U16(pub [u16; 8]);
+
+macro_rules! impl_vec {
+    ($name:ident, $inner:ty) => {
+        impl $name {
+            pub const fn from_raw(value: $inner) -> Self { Self(value) }
+            pub const fn inner(self) -> $inner { self.0 }
+        }
+    };
+}
+impl_vec!(VecI8, [i8; 32]);
+impl_vec!(VecI16, [i16; 16]);
+impl_vec!(VecI32, [i32; 8]);
+impl_vec!(VecF32, [f32; 8]);
+impl_vec!(Vec128U16, [u16; 8]);
+
+pub unsafe fn zero_i16() -> VecI16 { VecI16([0; 16]) }
+pub unsafe fn zero_i32() -> VecI32 { VecI32([0; 8]) }
+pub unsafe fn splat_i16(n: i16) -> VecI16 { VecI16([n; 16]) }
+pub unsafe fn splat_i32(n: i32) -> VecI32 { VecI32([n; 8]) }
+
+pub unsafe fn load_i8(src: *const i8) -> VecI8 { let mut v=[0;32]; unsafe{std::ptr::copy_nonoverlapping(src, v.as_mut_ptr(), 32)}; VecI8(v) }
+pub unsafe fn store_i8(dst: *mut i8, vec: VecI8) { unsafe{std::ptr::copy_nonoverlapping(vec.0.as_ptr(), dst, 32)} }
+pub unsafe fn load_u8(src: *const u8) -> VecI8 { let mut v=[0i8;32]; unsafe{std::ptr::copy_nonoverlapping(src.cast::<i8>(), v.as_mut_ptr(), 32)}; VecI8(v) }
+pub unsafe fn store_u8(dst: *mut u8, vec: VecI8) { unsafe{std::ptr::copy_nonoverlapping(vec.0.as_ptr().cast::<u8>(), dst, 32)} }
+pub unsafe fn load_i16(src: *const i16) -> VecI16 { let mut v=[0;16]; unsafe{std::ptr::copy_nonoverlapping(src, v.as_mut_ptr(), 16)}; VecI16(v) }
+pub unsafe fn store_i16(dst: *mut i16, vec: VecI16) { unsafe{std::ptr::copy_nonoverlapping(vec.0.as_ptr(), dst, 16)} }
+pub unsafe fn load_i32(src: *const i32) -> VecI32 { let mut v=[0;8]; unsafe{std::ptr::copy_nonoverlapping(src, v.as_mut_ptr(), 8)}; VecI32(v) }
+pub unsafe fn store_i32(dst: *mut i32, vec: VecI32) { unsafe{std::ptr::copy_nonoverlapping(vec.0.as_ptr(), dst, 8)} }
+pub unsafe fn store_u32(dst: *mut u32, vec: VecI32) { unsafe{std::ptr::copy_nonoverlapping(vec.0.as_ptr().cast::<u32>(), dst, 8)} }
+
+pub unsafe fn max_i16(a: VecI16, b: VecI16) -> VecI16 { let mut o=[0;16]; for i in 0..16{o[i]=a.0[i].max(b.0[i]);} VecI16(o) }
+pub unsafe fn min_i16(a: VecI16, b: VecI16) -> VecI16 { let mut o=[0;16]; for i in 0..16{o[i]=a.0[i].min(b.0[i]);} VecI16(o) }
+pub unsafe fn add_i16(a: VecI16, b: VecI16) -> VecI16 { let mut o=[0;16]; for i in 0..16{o[i]=a.0[i].wrapping_add(b.0[i]);} VecI16(o) }
+pub unsafe fn sub_i16(a: VecI16, b: VecI16) -> VecI16 { let mut o=[0;16]; for i in 0..16{o[i]=a.0[i].wrapping_sub(b.0[i]);} VecI16(o) }
+pub unsafe fn add_i32(a: VecI32, b: VecI32) -> VecI32 { let mut o=[0;8]; for i in 0..8{o[i]=a.0[i].wrapping_add(b.0[i]);} VecI32(o) }
+pub unsafe fn mul_high_i16(a: VecI16, b: VecI16) -> VecI16 { let mut o=[0;16]; for i in 0..16{o[i]=(((a.0[i] as i32)*(b.0[i] as i32)) >> 16) as i16;} VecI16(o) }
+
+pub type S = i32;
+pub unsafe fn shl_i16<const SHIFT: i32>(vec: VecI16) -> VecI16 { let mut o=[0;16]; for i in 0..16{o[i]=((vec.0[i] as i32) << SHIFT) as i16;} VecI16(o) }
+pub unsafe fn shift_mul_high_i16<const SHIFT: i32>(a: VecI16, b: VecI16) -> VecI16 { unsafe { mul_high_i16(shl_i16::<SHIFT>(a), b) } }
+pub unsafe fn nonzero_mask_i32(vec: VecI32) -> u16 { let mut m=0; for i in 0..8 { if vec.0[i] != 0 { m |= 1 << i; } } m }
+
+pub unsafe fn pack_i16_to_u8(a: VecI16, b: VecI16) -> VecI8 {
+    let mut o=[0i8;32];
+    for i in 0..16 { o[i] = a.0[i].clamp(0, u8::MAX as i16) as u8 as i8; }
+    for i in 0..16 { o[16+i] = b.0[i].clamp(0, u8::MAX as i16) as u8 as i8; }
+    VecI8(o)
+}
+
+pub unsafe fn madd_u8_to_i32(sum: VecI32, a: VecI8, b: VecI8) -> VecI32 {
+    let mut o=sum.0;
+    for lane in 0..8 {
+        let mut acc=0i32;
+        for j in 0..4 {
+            let k=lane*4+j;
+            acc += i32::from(a.0[k] as u8) * i32::from(b.0[k]);
+        }
+        o[lane]=o[lane].wrapping_add(acc);
+    }
+    VecI32(o)
+}
+
+pub unsafe fn madd_2xu8_to_i32(sum: VecI32, a: VecI8, b: VecI8, c: VecI8, d: VecI8) -> VecI32 {
+    let mut o=sum.0;
+    for lane in 0..8 {
+        let mut acc=0i32;
+        for j in 0..4 {
+            let k=lane*4+j;
+            acc += i32::from(a.0[k] as u8) * i32::from(b.0[k]);
+            acc += i32::from(c.0[k] as u8) * i32::from(d.0[k]);
+        }
+        o[lane]=o[lane].wrapping_add(acc);
+    }
+    VecI32(o)
+}
+
+pub unsafe fn i32_to_f32(vec: VecI32) -> VecF32 { let mut o=[0.0;8]; for i in 0..8{o[i]=vec.0[i] as f32;} VecF32(o) }
+pub unsafe fn zero_f32() -> VecF32 { VecF32([0.0; 8]) }
+pub unsafe fn splat_f32(n: f32) -> VecF32 { VecF32([n; 8]) }
+pub unsafe fn load_f32(src: *const f32) -> VecF32 { let mut v=[0.0;8]; unsafe{std::ptr::copy_nonoverlapping(src, v.as_mut_ptr(), 8)}; VecF32(v) }
+pub unsafe fn store_f32(dst: *mut f32, vec: VecF32) { unsafe{std::ptr::copy_nonoverlapping(vec.0.as_ptr(), dst, 8)} }
+pub unsafe fn add_f32(a: VecF32, b: VecF32) -> VecF32 { let mut o=[0.0;8]; for i in 0..8{o[i]=a.0[i]+b.0[i];} VecF32(o) }
+pub unsafe fn mul_f32(a: VecF32, b: VecF32) -> VecF32 { let mut o=[0.0;8]; for i in 0..8{o[i]=a.0[i]*b.0[i];} VecF32(o) }
+pub unsafe fn div_f32(a: VecF32, b: VecF32) -> VecF32 { let mut o=[0.0;8]; for i in 0..8{o[i]=a.0[i]/b.0[i];} VecF32(o) }
+pub unsafe fn max_f32(a: VecF32, b: VecF32) -> VecF32 { let mut o=[0.0;8]; for i in 0..8{o[i]=a.0[i].max(b.0[i]);} VecF32(o) }
+pub unsafe fn min_f32(a: VecF32, b: VecF32) -> VecF32 { let mut o=[0.0;8]; for i in 0..8{o[i]=a.0[i].min(b.0[i]);} VecF32(o) }
+pub unsafe fn madd_f32(a: VecF32, b: VecF32, c: VecF32) -> VecF32 { let mut o=[0.0;8]; for i in 0..8{o[i]=a.0[i].mul_add(b.0[i], c.0[i]);} VecF32(o) }
+pub unsafe fn sum_f32(vec: VecF32) -> f32 { vec.0.iter().sum() }
+pub unsafe fn reduce_add_f32s(vec: &[VecF32; 2]) -> f32 { vec[0].0.iter().chain(vec[1].0.iter()).sum() }
+
+pub unsafe fn load_extend_i8(src: *const i8) -> VecI16 { let mut o=[0;16]; for i in 0..16 { o[i]=unsafe{*src.add(i)} as i16; } VecI16(o) }
