+#![allow(clippy::all, clippy::nursery, clippy::pedantic, dead_code)]
+#![allow(clippy::undocumented_unsafe_blocks)]
+#![allow(unsafe_op_in_unsafe_fn)]
+
+use std::arch::wasm32::*;
+
+pub const INNER_ARCH: &str = "wasm-simd128";
+
+#[derive(Clone, Copy)]
+#[repr(C, align(16))]
+pub struct VecI8(pub v128, pub v128);
+#[derive(Clone, Copy)]
+#[repr(C, align(16))]
+pub struct VecI16(pub v128, pub v128);
+#[derive(Clone, Copy)]
+#[repr(C, align(16))]
+pub struct VecI32(pub v128, pub v128);
+#[derive(Clone, Copy)]
+#[repr(C, align(16))]
+pub struct VecF32(pub v128, pub v128);
+#[derive(Clone, Copy)]
+#[repr(transparent)]
+pub struct Vec128U16(pub v128);
+
+macro_rules! impl_vec2 {
+    ($name:ident) => {
+        impl $name {
+            #[inline(always)]
+            pub const fn from_raw(value: (v128, v128)) -> Self { Self(value.0, value.1) }
+            #[inline(always)]
+            pub const fn inner(self) -> (v128, v128) { (self.0, self.1) }
+        }
+    };
+}
+impl_vec2!(VecI8);
+impl_vec2!(VecI16);
+impl_vec2!(VecI32);
+impl_vec2!(VecF32);
+
+impl Vec128U16 {
+    #[inline(always)]
+    pub const fn from_raw(value: v128) -> Self { Self(value) }
+    #[inline(always)]
+    pub const fn inner(self) -> v128 { self.0 }
+}
+
+#[inline(always)]
+pub unsafe fn zero_i16() -> VecI16 { VecI16(i16x8_splat(0), i16x8_splat(0)) }
+#[inline(always)]
+pub unsafe fn zero_i32() -> VecI32 { VecI32(i32x4_splat(0), i32x4_splat(0)) }
+#[inline(always)]
