@@ -39,0 +43,24 @@ void initNetworkData() {
+#ifdef __EMSCRIPTEN__
+    std::ifstream netFile(EVALFILE, std::ios::binary | std::ios::ate);
+    if (!netFile) {
+        std::cerr << "Unable to open network file " << EVALFILE << std::endl;
+        std::abort();
+    }
+    std::streamsize netSize = netFile.tellg();
+    netFile.seekg(0, std::ios::beg);
+    size_t requiredBytes = static_cast<size_t>(netSize);
+    size_t paddedBytes = (requiredBytes + ALIGNMENT - 1) / ALIGNMENT * ALIGNMENT;
+    void* netPtr = aligned_alloc(ALIGNMENT, paddedBytes);
+    if (!netPtr) {
+        std::cerr << "Unable to allocate network data" << std::endl;
+        std::abort();
+    }
+    if (!netFile.read(reinterpret_cast<char*>(netPtr), netSize)) {
+        std::cerr << "Unable to read network file " << EVALFILE << std::endl;
+        std::abort();
+    }
+    globalNetworkData = reinterpret_cast<NetworkData*>(netPtr);
+#else
+    globalNetworkData = (NetworkData*)gNETWORKData;
+#endif
+
