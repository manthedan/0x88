FROM python:3.11-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends awscli zstd ca-certificates tar \
    && rm -rf /var/lib/apt/lists/*
RUN python -m pip install --no-cache-dir pyzstd

WORKDIR /work
COPY scripts/build_supervised_dataset_shards.py /work/scripts/build_supervised_dataset_shards.py
COPY cloud/aws/worker_build_supervised_dataset.sh /work/cloud/aws/worker_build_supervised_dataset.sh
RUN chmod +x /work/cloud/aws/worker_build_supervised_dataset.sh

ENTRYPOINT ["/work/cloud/aws/worker_build_supervised_dataset.sh"]
