{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiny-leela.local/contracts/failure_packet_v1.schema.json",
  "title": "Tiny Leela failure packet v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "id", "created_utc", "kind", "position", "model", "backend", "repro"],
  "properties": {
    "schema": { "const": "failure_packet_v1" },
    "id": { "type": "string" },
    "created_utc": { "type": "string" },
    "kind": { "type": "string", "enum": ["tactical_blunder", "backend_drift", "cache_drift", "illegal_move", "schema_violation", "performance_regression", "other"] },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "position": {
      "type": "object",
      "required": ["fen"],
      "properties": {
        "fen": { "type": "string" },
        "history_fens": { "type": "array", "items": { "type": "string" } },
        "legal_uci": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "model": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "onnx": { "type": "string" },
        "meta": { "type": "string" },
        "sha256": { "type": "string" }
      },
      "additionalProperties": true
    },
    "backend": {
      "type": "object",
      "required": ["runtime"],
      "properties": {
        "runtime": { "type": "string" },
        "execution_provider": { "type": "string" },
        "host_language": { "type": "string" },
        "target": { "type": "string" }
      },
      "additionalProperties": true
    },
    "search": { "type": "object", "additionalProperties": true },
    "teacher": { "type": "object", "additionalProperties": true },
    "observed": { "type": "object", "additionalProperties": true },
    "expected": { "type": "object", "additionalProperties": true },
    "repro": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "command": { "type": "string" },
        "env": { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "artifacts": { "type": "array", "items": { "type": "string" } }
  }
}
