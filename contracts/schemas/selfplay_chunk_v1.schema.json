{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tiny-leela.local/contracts/selfplay_chunk_v1.schema.json",
  "title": "Tiny Leela self-play chunk row v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "lane", "game_id", "ply", "fen", "legal_uci", "selected_uci", "policy", "wdl", "provenance"],
  "properties": {
    "schema": { "const": "selfplay_chunk_v1" },
    "lane": { "type": "string", "enum": ["gumbel_zero", "sup_sp", "eval_demo", "other"] },
    "game_id": { "type": "string" },
    "shard_id": { "type": "string" },
    "ply": { "type": "integer", "minimum": 0 },
    "fen": { "type": "string" },
    "history_fens": { "type": "array", "items": { "type": "string" } },
    "legal_uci": { "type": "array", "items": { "type": "string" } },
    "selected_uci": { "type": "string" },
    "policy": { "type": "object", "additionalProperties": { "type": "number" } },
    "wdl": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 },
    "q": { "type": "number" },
    "search": { "type": "object", "additionalProperties": true },
    "provenance": {
      "type": "object",
      "required": ["generator", "seed"],
      "properties": {
        "generator": { "type": "string" },
        "seed": { "type": ["integer", "string"] },
        "model_id": { "type": ["string", "null"] },
        "model_sha256": { "type": ["string", "null"] },
        "teacher": { "type": ["string", "null"] },
        "rules_only": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  }
}
