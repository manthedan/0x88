{
  "name": "lc0-webgpu",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser LC0/WebGPU chess engine research prototype.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && node --experimental-strip-types --test",
    "contracts:validate": "node --experimental-strip-types --test tests/contract_conformance.test.mjs",
    "eval:phase-b": "node eval/phase_b_metrics.mjs",
    "eval:search": "node eval/search_suite.mjs",
    "eval:runtime": "node --experimental-strip-types eval/runtime_suite.mjs",
    "rust:test": "cargo test --manifest-path rust/tiny_leela_core/Cargo.toml",
    "test:rust-ts-perft": "TINY_LEELA_RUN_RUST_PERFT=1 node --experimental-strip-types --test tests/perft_parity.test.mjs",
    "bench:movegen": "node --experimental-strip-types scripts/bench_movegen.mjs",
    "bench:search": "node --experimental-strip-types scripts/bench_search.mjs",
    "bench:rust-ts-board": "node --experimental-strip-types scripts/bench_rust_ts_board.mjs",
    "compare:rust-ts-search": "node --experimental-strip-types scripts/compare_rust_ts_search.mjs",
    "compare:rust-ts-board": "node --experimental-strip-types scripts/compare_rust_ts_board_encoding.mjs",
    "compare:rust-ts-onnx-eval": "node --experimental-strip-types scripts/compare_rust_ts_onnx_eval.mjs",
    "arena:rust-ts": "node --experimental-strip-types scripts/arena_rust_ts.mjs",
    "trace:puct": "node --experimental-strip-types scripts/compare_puct_trace.mjs",
    "rust:bench": "cargo run --release --manifest-path rust/tiny_leela_core/Cargo.toml --bin tiny-leela-rust-bench --",
    "rust:eval": "cargo run --release --manifest-path rust/tiny_leela_core/Cargo.toml --bin tiny-leela-rust-eval --",
    "rust:arena": "cargo run --release --features native-ort --manifest-path rust/tiny_leela_core/Cargo.toml --bin tiny-leela-rust-arena --",
    "rust:onnx-card": "cargo run --release --manifest-path rust/tiny_leela_core/Cargo.toml --bin tiny-leela-rust-onnx-card --",
    "rust:onnx-matrix": "cargo run --release --manifest-path rust/tiny_leela_core/Cargo.toml --bin tiny-leela-rust-onnx-matrix --",
    "rust:puct-sweep": "cargo run --release --manifest-path rust/tiny_leela_core/Cargo.toml --bin tiny-leela-rust-puct-sweep --",
    "rust:bayes-puct": "cargo run --release --manifest-path rust/tiny_leela_core/Cargo.toml --bin tiny-leela-rust-bayes-puct --",
    "eval:onnx-native-bench": ".venv-onnx/bin/python eval/onnx_native_inference_benchmark.py",
    "rust:wasm": "cargo build --release --target wasm32-unknown-unknown --manifest-path rust/tiny_leela_core/Cargo.toml",
    "eval:architecture": "node --experimental-strip-types eval/architecture_suite.mjs",
    "eval:playable": "node --experimental-strip-types eval/playable_suite.mjs",
    "eval:arena": "node --experimental-strip-types eval/arena_suite.mjs",
    "elo:arena": "node --experimental-strip-types scripts/elo_arena_parallel.mjs",
    "selfplay:generate": "node --experimental-strip-types scripts/selfplay_generate.mjs",
    "selfplay:gumbel-zero": "node --experimental-strip-types scripts/gumbel_zero_selfplay.mjs",
    "selfplay:gumbel-zero-report": ".venv-onnx/bin/python scripts/gumbel_zero_chunk_report.py",
    "selfplay:gumbel-to-training": ".venv-onnx/bin/python scripts/selfplay_gumbel_to_training.py",
    "selfplay:generate-atomic": "scripts/selfplay_chunk_generate_atomic.sh",
    "selfplay:validate": ".venv-onnx/bin/python scripts/selfplay_chunk_validate.py",
    "selfplay:mix-sweep": "node --experimental-strip-types scripts/selfplay_mix_sweep.mjs",
    "play:student": "node --experimental-strip-types scripts/play_student.mjs",
    "web:student": "node --experimental-strip-types scripts/serve_student_web.mjs",
    "web:client": "vite --host 0.0.0.0",
    "web:isolated:static": "node scripts/serve_isolated_static.mjs dist-client 5181",
    "build:client": "vite build --outDir dist-client",
    "distill:check": "python3 scripts/check_lc0_teacher.py",
    "distill:seed": "python3 scripts/export_seed_fens.py",
    "distill:query": "python3 scripts/query_lc0_teacher.py",
    "distill:validate": "python3 training/validate_teacher_labels.py",
    "stockfish:check": "python3 scripts/check_stockfish_teacher.py",
    "stockfish:query": "python3 scripts/query_stockfish_teacher.py",
    "lichess:ingest": "node --experimental-strip-types scripts/lichess_pgn_to_training.mjs",
    "distill:train": "python3 training/train_student.py",
    "train:residual:smoke": ".venv-onnx/bin/python training/train_residual_torch.py --train /tmp/hist_train.jsonl --out /tmp/residual_smoke.pt --onnx-out /tmp/residual_smoke.onnx --meta-out /tmp/residual_smoke.meta.json --channels 8 --blocks 1 --history-plies 2 --state-planes --epochs 1 --max-rows 128 --batch-size 32 --device cpu",
    "analysis:efficiency": ".venv-onnx/bin/python eval/model_efficiency_report.py",
    "analysis:model-manifest": ".venv-onnx/bin/python eval/build_model_manifest.py",
    "analysis:lint-eval-protocols": "python3 eval/lint_eval_protocols.py",
    "analysis:validate-cache-schema": "python3 scripts/validate_cache_schema.py",
    "deploy:onnxsim": ".venv-onnx/bin/python scripts/simplify_onnx_for_deploy.py",
    "eval:chess-ocean": "node --experimental-strip-types eval/chess_ocean_tests.mjs",
    "eval:pareto-sweep": ".venv-onnx/bin/python eval/pareto_sweep_report.py",
    "eval:onnx-parity": "node --experimental-strip-types eval/onnx_parity_check.mjs",
    "lc0:prepare-model-assets": "node scripts/lc0_prepare_model_assets.mjs",
    "lc0:pack-model": ".venv-onnx/bin/python scripts/convert_onnx_to_lc0web_pack.py",
    "lc0:eval-fixtures": "node --experimental-strip-types scripts/lc0_eval_fixtures.mjs",
    "lc0:eval-history": "node --experimental-strip-types scripts/lc0_eval_fixtures.mjs ../models/lc0-bestnets/onnx/t1-256x10-distilled-swa-2432500.batch1.f32.onnx fixtures/lc0/history.json",
    "lc0:eval-f16-fixtures": "node --experimental-strip-types scripts/lc0_eval_fixtures.mjs ../models/lc0-bestnets/onnx/t1-256x10-distilled-swa-2432500.batch1.f16.onnx fixtures/lc0/fen_only.json",
    "lc0:policy-only": "node --experimental-strip-types scripts/lc0_policy_only.mjs",
    "lc0:search": "node --experimental-strip-types scripts/lc0_search.mjs",
    "lc0:drift-sweep": "node --experimental-strip-types scripts/lc0_drift_sweep.mjs",
    "lc0:browser-wgsl-smokes": "node --experimental-strip-types scripts/lc0_browser_wgsl_smokes.mjs",
    "lc0:browser-hybrid-drift": "node --experimental-strip-types scripts/lc0_browser_hybrid_drift.mjs",
    "lc0:browser-hybrid-search-bench": "node --experimental-strip-types scripts/lc0_browser_hybrid_search_bench.mjs",
    "lc0:browser-hybrid-input-bench": "node --experimental-strip-types scripts/lc0_browser_hybrid_input_bench.mjs",
    "lc0:browser-hybrid-wgsl-batch-bench": "node --experimental-strip-types scripts/lc0_browser_hybrid_wgsl_batch_bench.mjs",
    "lc0:browser-wgsl-deferred-readback-bench": "node --experimental-strip-types scripts/lc0_browser_wgsl_deferred_readback_bench.mjs",
    "lc0:browser-wgsl-lifecycle-smoke": "node --experimental-strip-types scripts/lc0_browser_wgsl_lifecycle_smoke.mjs",
    "lc0:browser-hybrid-search-matrix": "node --experimental-strip-types scripts/lc0_browser_hybrid_search_matrix.mjs",
    "lc0:browser-hybrid-search-fixture-parity": "node --experimental-strip-types scripts/lc0_browser_hybrid_search_fixture_parity.mjs",
    "lc0:browser-hybrid-encoder-profile-matrix": "node --experimental-strip-types scripts/lc0_browser_hybrid_encoder_profile_matrix.mjs",
    "lc0:browser-hybrid-search-reuse-cache-matrix": "node --experimental-strip-types scripts/lc0_browser_hybrid_search_reuse_cache_matrix.mjs",
    "lc0:browser-ci-smoke": "node --experimental-strip-types scripts/lc0_browser_ci_smoke.mjs",
    "lc0:browser-wgsl-vs-ort-webgpu": "node --experimental-strip-types scripts/lc0_browser_wgsl_vs_ort_webgpu.mjs",
    "lc0:browser-runtime-arena": "node --experimental-strip-types scripts/lc0_browser_runtime_arena_bench.mjs",
    "lc0:runtime-arena-analyze": "node scripts/lc0_runtime_arena_analyze.mjs",
    "lc0:browser-runtime-fixed-suite": "node --experimental-strip-types scripts/lc0_browser_runtime_fixed_suite.mjs",
    "reckless:build-wasi": "node scripts/build_reckless_wasi.mjs",
    "reckless:build-browser-api": "npm run reckless:build-wasi && node scripts/build_reckless_browser_api.mjs",
    "reckless:build-browser-api-simd": "npm run reckless:build-wasi && RUSTFLAGS='-C target-feature=+simd128' RECKLESS_WASM_SIMD_NNUE=1 RECKLESS_BROWSER_API_WASM_OUT=public/reckless/reckless-browser-api-simd128.wasm node scripts/build_reckless_browser_api.mjs",
    "reckless:extract-nnue": "node scripts/extract_reckless_nnue_asset.mjs",
    "reckless:build-browser-api-simd-external": "npm run reckless:build-wasi && npm run reckless:extract-nnue && RUSTFLAGS='-C target-feature=+simd128' RECKLESS_WASM_SIMD_NNUE=1 RECKLESS_BROWSER_API_EXTERNAL_NNUE=1 RECKLESS_BROWSER_API_WASM_OUT=public/reckless/reckless-browser-api-simd128-external.wasm node scripts/build_reckless_browser_api.mjs",
    "reckless:build-simd-wasi": "RUSTFLAGS='-C target-feature=+simd128' RECKLESS_WASM_SIMD_NNUE=1 RECKLESS_WASM_OUT=public/reckless/reckless-simd128.wasm node scripts/build_reckless_wasi.mjs",
    "reckless:build-production": "node scripts/build_reckless_release_assets.mjs",
    "reckless:inspect-simd": "node scripts/inspect_wasm_simd.mjs public/reckless/reckless.wasm public/reckless/reckless-simd128.wasm",
    "reckless:inspect-sections": "node scripts/inspect_wasm_sections.mjs public/reckless/reckless.wasm public/reckless/reckless-simd128.wasm --out docs/reckless_wasm_section_breakdown_2026-06-04.json",
    "reckless:probe-nnue-accum-simd": "node scripts/reckless_wasm_nnue_accum_probe.mjs",
    "reckless:probe-nnue-activate-simd": "node scripts/reckless_wasm_nnue_activate_probe.mjs",
    "reckless:probe-browser-api": "node scripts/probe_reckless_browser_api_facade.mjs",
    "reckless:wasm-opt-experiment": "node scripts/reckless_wasm_opt_experiment.mjs",
    "reckless:build-lite-wasi": "RECKLESS_BUILD_DIR=.local_engines/reckless-lite-wasi-src RECKLESS_EVALFILE=.local_engines/reckless-nets/v53-0ba42a8c.nnue RECKLESS_L1_SIZE=512 RECKLESS_WASM_OUT=public/reckless/reckless-v53-l1-512.wasm node scripts/build_reckless_wasi.mjs",
    "viridithas:build-wasi": "node scripts/build_viridithas_wasi.mjs",
    "viridithas:build-simd-wasi": "VIRIDITHAS_WASM_SIMD=1 VIRIDITHAS_WASM_OUT=public/viridithas/viridithas-simd128.wasm node scripts/build_viridithas_wasi.mjs",
    "viridithas:smoke": "node scripts/viridithas_wasi_smoke.mjs --wasm public/viridithas/viridithas-simd128.wasm --depth 2 --repeat 2",
    "lc0:battle": "node --experimental-strip-types scripts/lc0_engine_battle.mjs",
    "eval:search-arena-sharded": "node --experimental-strip-types eval/search_mode_arena_sharded.mjs"
  },
  "devDependencies": {
    "binaryen": "^130.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@tanstack/query-core": "^5.101.0",
    "@tanstack/store": "^0.11.0",
    "chessground": "^9.2.1",
    "onnxruntime-web": "^1.25.1",
    "stockfish": "^18.0.7"
  }
}
