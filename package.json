    "reckless:build-browser-api": "npm run reckless:build-wasi && node scripts/build_reckless_browser_api.mjs",
    "reckless:build-browser-api-simd": "npm run reckless:build-wasi && RUSTFLAGS='-C target-feature=+simd128' RECKLESS_WASM_SIMD_NNUE=1 RECKLESS_BROWSER_API_WASM_OUT=public/reckless/reckless-browser-api-simd128.wasm node scripts/build_reckless_browser_api.mjs",
    "reckless:extract-nnue": "node scripts/extract_reckless_nnue_asset.mjs",
    "reckless:build-browser-api-simd-external": "npm run reckless:build-wasi && npm run reckless:extract-nnue && RUSTFLAGS='-C target-feature=+simd128' RECKLESS_WASM_SIMD_NNUE=1 RECKLESS_BROWSER_API_EXTERNAL_NNUE=1 RECKLESS_BROWSER_API_WASM_OUT=public/reckless/reckless-browser-api-simd128-external.wasm node scripts/build_reckless_browser_api.mjs",
