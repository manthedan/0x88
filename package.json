    "lc0:tvmjs-webgpu-smoke": "node scripts/lc0_tvmjs_webgpu_smoke.mjs",
    "lc0:tvmjs-webgpu-fixed-suite": "node --experimental-strip-types scripts/lc0_tvmjs_webgpu_fixed_suite.mjs",
